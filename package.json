{
  "name": "@aundal/opencode-token-monsters",
  "version": "0.1.0",
  "description": "OpenCode plugin that shows Token Monsters token usage breakdowns in the TUI sidebar.",
  "author": "aundal",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aundal/opencode-token-monsters.git"
  },
  "homepage": "https://github.com/aundal/opencode-token-monsters#readme",
  "bugs": {
    "url": "https://github.com/aundal/opencode-token-monsters/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target bun --external @opencode-ai/plugin --external @opentui/solid --external solid-js --external gpt-tokenizer && tsc --emitDeclarationOnly",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "token-usage",
    "tokens",
    "tui"
  ],
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.7",
    "@opentui/solid": "^0.4.0",
    "bun-types": "^1.2.19",
    "@types/node": "^24.0.7",
    "solid-js": "^1.9.13",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0",
    "@opentui/solid": ">=0.4.0",
    "solid-js": ">=1.9.0"
  }
}
